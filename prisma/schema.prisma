generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Global Configuration to allow Admin to edit prices and the 31-day countdown without touching code
model SiteConfig {
  id              String   @id @default(cuid())
  basePrice       Int      @default(3000)
  preOrderPrice   Int      @default(2500)
  countdownEndsAt DateTime 
  updatedAt       DateTime @updatedAt
}

// Core Order Logic mapping all required fields for strict delivery and tracking
model Order {
  id               String    @id @default(cuid()) 
  orderNumber      String    @unique // The highly unique ID (e.g., ABU-HAY-9842) sent via ZeptoMail
  name             String
  email            String
  whatsapp         String
  quantity         Int
  totalAmount      Int
  deliveryMode     String    // "PICKUP_AT_LAUNCH" or "HOME_DELIVERY"
  
  // Location Data (Mandatory regardless of delivery mode to secure delivery fees)
  state            String
  city             String
  address          String
  nearestPark      String
  
  // Security & Payment Tracking
  paymentStatus    String    @default("PENDING") // PENDING, SUCCESS, FAILED
  dvaReference     String?   @unique // Paystack Reference
  dvaAccountNumber String?   
  dvaBankName      String?
  dvaExpiresAt     DateTime? 
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Isolated table for the Sponsorship workflow
model Sponsor {
  id               String    @id @default(cuid())
  name             String?   // Nullable for anonymous sponsors
  email            String   // <-- ADD THIS LINE
  quantity         Int
  totalAmount      Int
  
  // Security & Payment Tracking
  paymentStatus    String    @default("PENDING")
  dvaReference     String?   @unique
  dvaAccountNumber String?
  dvaBankName      String?
  dvaExpiresAt     DateTime?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
